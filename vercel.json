{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/blog/:slug",
      "destination": "/api/blog-meta?slug=:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],

  "functions": {
    "api/**/*.js": {
      "includeFiles": "server_data/**"
    },
    "api/blog-meta.js": {
      "includeFiles": "dist/index.html"
    }
  }
}
